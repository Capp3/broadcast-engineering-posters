# EditorConfig helps maintain consistent coding styles between editors.
# https://editorconfig.org/

root = true

###############################################################################
# Global defaults
###############################################################################

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

###############################################################################
# Markdown
###############################################################################

[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = off

###############################################################################
# LaTeX
###############################################################################

[*.{tex,sty,cls,bib}]
indent_size = 4

###############################################################################
# TikZ / PGF
###############################################################################

[*.tikz]
indent_size = 4

###############################################################################
# YAML
###############################################################################

[*.{yml,yaml}]
indent_size = 2

###############################################################################
# JSON
###############################################################################

[*.json]
indent_size = 2

###############################################################################
# XML / SVG
###############################################################################

[*.{xml,svg}]
indent_size = 2

###############################################################################
# Shell Scripts
###############################################################################

[*.{sh,bash}]
indent_size = 4

###############################################################################
# Python (helper scripts)
###############################################################################

[*.py]
indent_size = 4

###############################################################################
# Makefiles
###############################################################################

[{Makefile,makefile,GNUmakefile}]
indent_style = tab

###############################################################################
# Git
###############################################################################

[*.git*]
indent_size = 4

###############################################################################
# Plain Text
###############################################################################

[*.txt]
trim_trailing_whitespace = false