# Auto-detect text files and normalise to LF
* text=auto eol=lf

# LaTeX
*.tex text
*.sty text
*.cls text
*.bib text

# Documentation
*.md  text
*.txt text

# Scripts
*.sh  text eol=lf
*.py  text eol=lf

# Configuration
*.yml text
*.yaml text
*.json text
*.toml text

# Images
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.svg text

# Fonts
*.ttf binary
*.otf binary
